package github.com/hashicorp/terraform-provider-azurerm/internal/vcr
import (
	"bytes"
	"compress/gzip"
	"io"
	"os"
	"path/filepath"
)
func (fs *GzipFS) ReadFile(name string) ([]byte, error) {
	f, err := os.Open(name)
	if err != nil {
		return nil, err
	}
	defer f.Close()

	r, err := gzip.NewReader(f)
	if err != nil {
		return nil, err
	}
	defer r.Close()

	return io.ReadAll(r)
}
