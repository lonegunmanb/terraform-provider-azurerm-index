func (r BatchJobResource) expandEnvironmentSettings(input map[string]string) *[]jobs.EnvironmentSetting {
	if len(input) == 0 {
		return nil
	}

	m := make([]jobs.EnvironmentSetting, 0, len(input))
	for k, v := range input {
		m = append(m, jobs.EnvironmentSetting{
			Name:  k,
			Value: pointer.To(v),
		})
	}
	return &m
}
