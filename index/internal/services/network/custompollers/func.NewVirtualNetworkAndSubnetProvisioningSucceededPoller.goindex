func NewVirtualNetworkAndSubnetProvisioningSucceededPoller(client *network.Client, id *commonids.SubnetId) pollers.PollerType {
	return &virtualNetworkAndSubnetProvisioningSucceededPoller{
		client: client,
		id:     id,
	}
}
